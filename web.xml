<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Bloom E-Commerce Store</display-name>
  <description>Distributed E-Commerce System — Advanced Java Mini Project</description>

  <!-- ── Welcome file ─────────────────────────────────── -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- ── Session timeout (30 minutes) ────────────────── -->
  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>

  <!-- ── Error pages ──────────────────────────────────── -->
  <error-page>
    <error-code>404</error-code>
    <location>/error-404.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/error-500.jsp</location>
  </error-page>

  <!-- ── Security: protect /admin/* ───────────────────── -->
  <security-constraint>
    <web-resource-collection>
      <web-resource-name>Admin Area</web-resource-name>
      <url-pattern>/admin/*</url-pattern>
    </web-resource-collection>
    <!-- Using session-based admin check in servlets instead of container security -->
  </security-constraint>

  <!-- ── JSTL taglib (if needed for older containers) ── -->
  <jsp-config>
    <taglib>
      <taglib-uri>http://java.sun.com/jsp/jstl/core</taglib-uri>
      <taglib-location>/WEB-INF/lib/jstl.jar</taglib-location>
    </taglib>
  </jsp-config>

</web-app>
